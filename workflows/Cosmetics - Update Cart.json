    {
      "parameters": {
        "jsCode": "// Format Cart Data ထဲမှ လက်ဆင့်ကမ်းလာသော နာမည်အမှန်နှင့် အရေအတွက်ကို ယူခြင်း\nconst finalProduct = $input.first().json.final_product || $('Format Cart Data').first().json.final_product;\nconst finalQty = $input.first().json.final_qty || $('Format Cart Data').first().json.final_qty;\n\nreturn [{\n    json: {\n        status: \"success\",\n        product_name: finalProduct,\n        quantity: finalQty\n    }\n}];"
      },
