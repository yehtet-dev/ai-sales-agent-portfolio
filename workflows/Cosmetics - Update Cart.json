    {
      "parameters": {
        "jsCode": "// 1. ရှေ့က Code (Single Match) မှ ပစ္စည်းနာမည်ကို ယူမည်\nconst exactProductName = $('Code in JavaScript').first().json.product['Product Name'];\n\n// 2. Trigger မှ Data များကို ယူမည်\nconst triggerData = $('Update Cart').first().json.query;\nconst qtyToAdd = parseInt(triggerData.quantity) || 1;\nconst senderId = triggerData.sender_id || triggerData.senderId;\n\n// 3. 🌟 အသစ်ထည့်လိုက်သော Database Node မှ လက်ရှိ Cart အဟောင်းကို ဆွဲယူမည် 🌟\nconst dbNode = $('Get Existing Cart').first();\nlet currentCartString = (dbNode && dbNode.json && dbNode.json.ai_json) ? dbNode.json.ai_json : \"[]\";\n\nlet cart = [];\ntry {\n    cart = JSON.parse(currentCartString);\n} catch(e) {}\n\n// 4. ပစ္စည်းအဟောင်းရှိမရှိ စစ်ဆေးပြီး ပေါင်းထည့်မည်\nconst existingItemIndex = cart.findIndex(item => item.product_name === exactProductName);\n\nif (existingItemIndex > -1) {\n    cart[existingItemIndex].quantity += qtyToAdd; // ပါပြီးသားဆို အရေအတွက်တိုးမည်\n} else {\n    cart.push({\n        product_name: exactProductName,\n        quantity: qtyToAdd // မပါသေးလျှင် အသစ်ထည့်မည်\n    });\n}\n\n// 5. Upsert သို့ ပို့ရန် ပြင်ဆင်မည်\nreturn [{\n    json: {\n        sender_id: senderId,\n        cart_data: JSON.stringify(cart),\n        final_product: exactProductName,\n        final_qty: qtyToAdd\n    }\n}];"
      },
