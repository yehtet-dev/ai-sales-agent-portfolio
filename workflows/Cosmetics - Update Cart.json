    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst triggerData = $('Update Cart').first().json.query;\nconst keyword = (triggerData.keyword || \"\").toLowerCase();\n\n// ၁။ Filter လုပ်မည့်အစား Code ဖြင့် တိုက်ရိုက် စစ်ထုတ်ခြင်း\nconst matchedItems = items.filter(item => {\n    const productName = (item.json['Product Name'] || \"\").toLowerCase();\n    const instock = parseInt(item.json['Instock']) || 0;\n    // နာမည်လည်းပါဝင်ရမည်၊ Stock လည်း > 0 ဖြစ်ရမည်\n    return productName.includes(keyword) && instock > 0;\n});\n\nconst count = matchedItems.length;\n\n// ၂။ ရလဒ်အပေါ်မူတည်၍ Status ခွဲထုတ်ခြင်း\nif (count === 0) {\n    return [{ json: { status: \"not_found\" } }];\n} else if (count === 1) {\n    return [{ json: { status: \"single_match\", product: matchedItems[0].json } }];\n} else {\n    let variationsText = \"\";\n    matchedItems.forEach((item, index) => {\n        variationsText += `${index + 1}. ${item.json['Product Name']} - ${item.json['Price_Retail']} Ks\\n`;\n    });\n    return [{ json: { status: \"multiple_matches\", variations_list: variationsText } }];\n}"
      },
